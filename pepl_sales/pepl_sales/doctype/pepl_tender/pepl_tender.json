  },
  {
   "fieldname": "result_column_break",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "evaluation_criteria",
   "fieldtype": "Select",
   "label": "Evaluation Criteria",
   "options": "\nItem Wise\nItem Wise Consignee Wise\nTotal Bid Value\nItem Total Value\nBuyer Selected\nOther"
  },
  {
   "fieldname": "result_published_date",
   "fieldtype": "Datetime",
   "label": "Result Published Date / Time"
  },
  {
   "fieldname": "total_evaluated_tender_value",
   "fieldtype": "Currency",
   "label": "Total Evaluated Tender Value"
  },
  {
   "fieldname": "splitting_applicable",
   "fieldtype": "Check",
   "label": "Split Award Applicable",
   "default": "0"
  },
  {
   "fieldname": "splitting_ratio",
   "fieldtype": "Data",
   "label": "Splitting Ratio",
   "depends_on": "eval:doc.splitting_applicable==1",
