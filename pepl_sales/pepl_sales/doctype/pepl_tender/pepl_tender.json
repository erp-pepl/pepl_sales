   "depends_on": "eval:doc.linked_sales_order"
  },
  {
   "fieldname": "linked_sales_order",
   "fieldtype": "Link",
   "label": "Linked Sales Order",
   "options": "Sales Order",
   "read_only": 1,
   "description": "Auto-created via 'Create Sales Order' button"
