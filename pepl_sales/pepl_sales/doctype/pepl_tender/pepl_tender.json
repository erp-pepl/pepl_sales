   "fieldname": "outcome_date",
   "fieldtype": "Date",
   "label": "Outcome Date",
   "depends_on": "eval:doc.status==\"Won\" || doc.status==\"Partially Won\" || doc.status==\"Lost\" || doc.status==\"Cancelled\" || doc.status==\"No Bid\""
