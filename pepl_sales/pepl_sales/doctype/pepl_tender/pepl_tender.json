  },
  {
   "fieldname": "customer_po_received",
   "fieldtype": "Check",
   "label": "Customer PO/LOA Received",
   "default": "0"
  },
  {
   "fieldname": "po_number",
   "fieldtype": "Data",
   "label": "Customer PO Number",
   "depends_on": "eval:doc.customer_po_received==1"
  },
  {
   "fieldname": "po_date",
   "fieldtype": "Date",
   "label": "PO Date",
   "depends_on": "eval:doc.customer_po_received==1"
  },
  {
   "fieldname": "po_payment_terms",
   "fieldtype": "Link",
   "label": "Payment Terms",
   "options": "Payment Terms Template",
   "depends_on": "eval:doc.customer_po_received==1"
  },
  {
   "fieldname": "po_amount_received",
   "fieldtype": "Currency",
   "label": "Total PO Value (INR)",
