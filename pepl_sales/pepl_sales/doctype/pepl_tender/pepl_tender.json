  {
   "fieldname": "po_schedule_section",
   "fieldtype": "Section Break",
   "label": "PO Schedule (Sl. No. wise delivery batches)",
   "depends_on": "eval:doc.customer_po_received==1",
   "description": "Add one row per delivery batch. Same item can be added multiple times with different delivery dates and quantities."
  },
  {
   "fieldname": "po_schedule",
   "fieldtype": "Table",
   "label": "PO Schedule",
   "options": "PEPL Tender PO Schedule",
   "depends_on": "eval:doc.customer_po_received==1"
  },
  {
   "fieldname": "so_section",
   "fieldtype": "Section Break",
